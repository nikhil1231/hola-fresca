 "prepTime": "PT45M",
 "recipeId": "693adbb51101204cae74ecbc",
 "servingSize": 546,
 "slug": "crispy-chicken-goujons-and-cheesy-wedges",
 "steps": [
  {
   "id": "6a5a17be60ad7c1d4660444f",
   "index": 1,
   "instructions": "<p>Preheat your oven to 220\u00b0C/200\u00b0C fan/gas mark 7.</p>\n<p>Chop the <strong>potatoes</strong> into 2cm wide wedges (no need to peel).</p>\n<p>Pop the <strong>wedges</strong> onto a large baking tray. Drizzle with <strong>oil</strong>, season with <strong>salt</strong> and <strong>pepper</strong>, then toss to coat. Spread out in a single layer. <span style=\"color: rgb(45, 194, 107)\"><strong>TIP:</strong></span> <em>Use two baking trays if necessary.</em></p>\n<p>When the oven is hot, roast on the top shelf until golden, 25-35 mins. Turn halfway through.</p>",
   "instructionsHTML": "<p>Preheat your oven to 220\u00b0C/200\u00b0C fan/gas mark 7.</p>\n<p>Chop the <strong>potatoes</strong> into 2cm wide wedges (no need to peel).</p>\n<p>Pop the <strong>wedges</strong> onto a large baking tray. Drizzle with <strong>oil</strong>, season with <strong>salt</strong> and <strong>pepper</strong>, then toss to coat. Spread out in a single layer. <span style=\"color: rgb(45, 194, 107)\"><strong>TIP:</strong></span> <em>Use two baking trays if necessary.</em></p>\n<p>When the oven is hot, roast on the top shelf until golden, 25-35 mins. Turn halfway through.</p>",
   "instructionsMarkdown": "<p>Preheat your oven to 220\u00b0C/200\u00b0C fan/gas mark 7.</p>\n<p>Chop the <strong>potatoes</strong> into 2cm wide wedges (no need to peel).</p>\n<p>Pop the <strong>wedges</strong> onto a large baking tray. Drizzle with <strong>oil</strong>, season with <strong>salt</strong> and <strong>pepper</strong>, then toss to coat. Spread out in a single layer. <span style=\"color: rgb(45, 194, 107)\"><strong>TIP:</strong></span> <em>Use two baking trays if necessary.</em></p>\n<p>When the oven is hot, roast on the top shelf until golden, 25-35 mins. Turn halfway through.</p>",
   "images": [
    {
     "path": "/693adbb51101204cae74ecbc/step-baa42500.jpg",
